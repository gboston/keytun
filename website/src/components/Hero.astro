---
// ABOUTME: Hero section with tagline, call-to-action buttons, and terminal demo.
// ABOUTME: First thing visitors see — communicates what keytun does in one glance.

import TerminalDemo from './TerminalDemo.astro';
---

<section class="hero">
	<div class="hero-glow" aria-hidden="true"></div>
	<div class="hero-badge hero-anim" style="--delay: 0">Think ngrok, but for keystrokes</div>
	<h1 class="hero-anim" style="--delay: 1">
		Let your colleague<br />
		<span class="gradient-text">type into your terminal.</span>
	</h1>
	<p class="hero-sub hero-anim" style="--delay: 2">
		You're screensharing. They need to run a command. Stop dictating characters.
		Give them a session code and let them type directly.
	</p>
	<div class="hero-actions hero-anim" style="--delay: 3">
		<a href="#install" class="btn btn-primary">
			<span class="btn-icon">↓</span> Install keytun
		</a>
		<a href="/join" class="btn btn-ghost">Join from browser</a>
		<a href="#how-it-works" class="btn btn-ghost">See how it works</a>
	</div>

	<TerminalDemo />
</section>

<style>
	.hero {
		padding: 140px 24px 80px;
		text-align: center;
		max-width: 1100px;
		margin: 0 auto;
		position: relative;
	}

	.hero-glow {
		position: absolute;
		top: 40px;
		left: 50%;
		transform: translateX(-50%);
		width: 900px;
		height: 600px;
		background: radial-gradient(ellipse at 50% 30%, rgba(255, 79, 56, 0.13) 0%, rgba(255, 186, 48, 0.06) 45%, transparent 70%);
		pointer-events: none;
		z-index: 0;
	}

	.hero-badge {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--accent-coral);
		background: var(--badge-bg);
		border: 1px solid var(--badge-border);
		padding: 6px 18px;
		border-radius: 50px;
		margin-bottom: 28px;
		position: relative;
		z-index: 1;
	}

	:global([data-theme="dark"]) .hero-badge {
		box-shadow: 0 0 16px rgba(255, 79, 56, 0.18), 0 0 0 1px rgba(255, 79, 56, 0.08) inset;
	}

	:global([data-theme="dark"]) .hero-glow {
		background: radial-gradient(ellipse at 50% 30%, rgba(255, 79, 56, 0.20) 0%, rgba(255, 186, 48, 0.10) 45%, transparent 70%);
	}

	.hero h1 {
		font-family: var(--font-display);
		font-size: clamp(2.4rem, 6vw, 4rem);
		font-weight: 700;
		line-height: 1.15;
		margin-bottom: 24px;
		letter-spacing: -0.03em;
		position: relative;
		z-index: 1;
	}

	.gradient-text {
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-sub {
		font-size: 1.15rem;
		color: var(--text-dim);
		max-width: 600px;
		margin: 0 auto 36px;
		line-height: 1.7;
	}

	.hero-actions {
		display: flex;
		gap: 16px;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 40px;
	}

	@media (max-width: 768px) {
		.hero {
			padding: 120px 20px 60px;
		}
	}

	.hero-anim {
		opacity: 0;
		transform: translateY(20px);
		animation: hero-fade-in 0.6s ease-out forwards;
		animation-delay: calc(var(--delay) * 0.15s + 0.1s);
	}

	@keyframes hero-fade-in {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 480px) {
		.hero {
			padding: 100px 16px 48px;
		}

		.hero h1 {
			font-size: 2rem;
		}

		.hero-sub {
			font-size: 1rem;
		}

		.hero-actions {
			flex-direction: column;
			align-items: stretch;
			margin-bottom: 48px;
		}
	}
</style>
