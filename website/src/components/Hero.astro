---
// ABOUTME: Hero section with tagline, call-to-action buttons, and terminal demo.
// ABOUTME: First thing visitors see — communicates what keytun does in one glance.

import TerminalDemo from './TerminalDemo.astro';
---

<section class="hero">
	<div class="hero-badge hero-anim" style="--delay: 0">Think ngrok, but for keystrokes</div>
	<h1 class="hero-anim" style="--delay: 1">
		Let your colleague<br />
		<span class="gradient-text">type into your terminal.</span>
	</h1>
	<p class="hero-sub hero-anim" style="--delay: 2">
		You're screensharing. They need to run a command. Stop dictating characters —
		give them a session code and let them type directly.
	</p>
	<div class="hero-actions hero-anim" style="--delay: 3">
		<a href="#install" class="btn btn-primary">
			<span class="btn-icon">↓</span> Install keytun
		</a>
		<a href="#how-it-works" class="btn btn-ghost">See how it works</a>
	</div>

	<TerminalDemo />
</section>

<style>
	.hero {
		padding: 140px 24px 80px;
		text-align: center;
		max-width: 1100px;
		margin: 0 auto;
	}

	.hero-badge {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--accent-coral);
		background: var(--badge-bg);
		border: 1px solid var(--badge-border);
		padding: 6px 18px;
		border-radius: 50px;
		margin-bottom: 28px;
	}

	.hero h1 {
		font-size: clamp(2.4rem, 6vw, 4rem);
		font-weight: 700;
		line-height: 1.15;
		margin-bottom: 24px;
		letter-spacing: -0.02em;
	}

	.gradient-text {
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-sub {
		font-size: 1.15rem;
		color: var(--text-dim);
		max-width: 600px;
		margin: 0 auto 36px;
		line-height: 1.7;
	}

	.hero-actions {
		display: flex;
		gap: 16px;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 64px;
	}

	@media (max-width: 768px) {
		.hero {
			padding: 120px 20px 60px;
		}
	}

	.hero-anim {
		opacity: 0;
		transform: translateY(20px);
		animation: hero-fade-in 0.6s ease-out forwards;
		animation-delay: calc(var(--delay) * 0.12s + 0.1s);
	}

	@keyframes hero-fade-in {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 480px) {
		.hero h1 {
			font-size: 2rem;
		}

		.hero-actions {
			flex-direction: column;
			align-items: center;
		}
	}
</style>
