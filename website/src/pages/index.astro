---
// ABOUTME: Landing page for keytun - keyboard tunnel for developers.
// ABOUTME: Composes all section components within the shared Layout.

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ProblemSection from '../components/ProblemSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Showcase from '../components/Showcase.astro';
import Features from '../components/Features.astro';
import Install from '../components/Install.astro';
import Roadmap from '../components/Roadmap.astro';

import Footer from '../components/Footer.astro';
---

<Layout title="keytun - Let remote colleagues type into your terminal" description="Lightweight keyboard tunnel for pair programming over screenshare. Share a session code, and your colleague types into your terminal in real time.">
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			"name": "keytun",
			"description": "Lightweight keyboard tunnel for pair programming over screenshare. Share a session code, and your colleague types into your terminal in real time.",
			"applicationCategory": "DeveloperApplication",
			"operatingSystem": "macOS, Linux",
			"license": "https://www.gnu.org/licenses/agpl-3.0.html",
			"url": "https://keytun.com",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			}
		})} />
	</Fragment>
	<Nav />
	<main id="main-content">
		<Hero />
		<ProblemSection />
		<HowItWorks />
		<Showcase />
		<Features />
		<Install />
		<Roadmap />
	</main>
	<Footer />
</Layout>
